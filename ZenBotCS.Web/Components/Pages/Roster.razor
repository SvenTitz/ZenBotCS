@page "/clans/{ClanTag}"
@page "/clans/{ClanTag}/roster"
@page "/roster/{ClanTag}"
@using System.Security.Claims
@inject RosterService Rosters
@inject ClanNameService ClanNames
@inject PlayerSuggestionService PlayerSuggestions
@inject RosterImageService RosterImage
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject ILogger<Roster> Logger

<PageTitle>Roster @_clanName</PageTitle>

<ClanTabs ClanTag="@ClanTag" Active="roster" />

<AuthorizeView Roles="@AuthRoles.RosterAccess" Context="auth">
    <NotAuthorized>
        @if (auth.User.Identity?.IsAuthenticated == true)
        {
            <MudAlert Severity="Severity.Warning">
                Signed in as <b>@auth.User.Identity.Name</b>, but your account doesn't have roster access.
            </MudAlert>
        }
        else
        {
            <MudAlert Severity="Severity.Info">
                Please <MudLink Href="/account/login">sign in with Discord</MudLink> to view this roster.
            </MudAlert>
        }
    </NotAuthorized>
    <Authorized>
        <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Class="mb-4">
            <div>
                <MudText Typo="Typo.h5">@_clanName</MudText>
                <MudText Typo="Typo.caption" Style="font-family:monospace;">@ClanTag</MudText>
            </div>
            <MudSpacer />
            <MudButton OnClick="OpenAdd" StartIcon="@Icons.Material.Filled.PersonAdd"
                       Variant="Variant.Outlined" Size="Size.Small" Class="mr-2">
                Add player
            </MudButton>
            <MudButton OnClick="SolveRoster" StartIcon="@Icons.Material.Filled.AutoFixHigh"
                       Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Class="mr-2"
                       Disabled="@(_signups is null || _signups.Count == 0 || _solving)">
                Solve roster
            </MudButton>
            <MudButton OnClick="DownloadImage" StartIcon="@Icons.Material.Filled.Download"
                       Variant="Variant.Outlined" Size="Size.Small" Class="mr-2"
                       Disabled="@(_signups is null || _signups.Count == 0)">
                Download image
            </MudButton>
            @if (_hidden is { Count: > 0 })
            {
                <MudButton OnClick="@(() => _showHidden = !_showHidden)" StartIcon="@Icons.Material.Filled.VisibilityOff"
                           Variant="Variant.Text" Size="Size.Small" Class="mr-2">
                    @(_showHidden ? "Hide hidden" : $"Show hidden ({_hidden.Count})")
                </MudButton>
            }
            <div>
                <MudText Typo="Typo.caption" Class="d-block">War size</MudText>
                <MudToggleGroup T="int" @bind-Value="_targetSize" Size="Size.Small" Color="Color.Primary">
                    <MudToggleItem Value="15">15v15</MudToggleItem>
                    <MudToggleItem Value="30">30v30</MudToggleItem>
                </MudToggleGroup>
            </div>
        </MudStack>

        <MudText Typo="Typo.body2" Class="mb-4 mud-text-secondary">
            Tick the days each player should play. Defaults to their declared availability; changes save automatically.
        </MudText>

        @if (_signups is null)
        {
            <MudProgressCircular Indeterminate="true" />
        }
        else if (_signups.Count == 0)
        {
            <MudText>No active signups for this clan.</MudText>
        }
        else
        {
            <div class="roster-scroll" @ref="_scrollContainer">
                <MudTable Items="_signups" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.None">
                    <HeaderContent>
                        <MudTh Class="sticky-col">Player</MudTh>
                        <MudTh>Tag</MudTh>
                        <MudTh Style="text-align:center">TH</MudTh>
                        @if (_champStyle)
                        {
                            <MudTh Style="text-align:center">Max&nbsp;Def</MudTh>
                        }
                        @for (var d = 1; d <= 7; d++)
                        {
                            var dayNum = d;
                            var flag = DayFlags[d - 1];
                            var count = DayCount(flag);
                            <MudTh Style="text-align:center">
                                D@(dayNum)<br />
                                <MudText Inline="true" Typo="Typo.body2" Color="@CountColor(count)"><b>@count</b></MudText>
                            </MudTh>
                        }
                        <MudTh Style="text-align:center">Bonus</MudTh>
                        <MudTh Class="sticky-col-right" Style="text-align:center">
                            <span class="wp-abbr">WP</span><span class="wp-full">War pref</span>
                        </MudTh>
                        <MudTh Class="sticky-col-days" Style="text-align:center" title="Days rostered">#</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Player" Class="sticky-col">
                            <div style="display:flex;align-items:center;gap:2px;">
                                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Dense="true"
                                         AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft">
                                    <MudMenuItem Icon="@Icons.Material.Filled.SwapHoriz" OnClick="@(() => OpenMove(context))">Move to clan…</MudMenuItem>
                                    <MudMenuItem Icon="@Icons.Material.Filled.VisibilityOff" OnClick="@(() => HidePlayer(context))">Hide</MudMenuItem>
                                    <MudMenuItem Icon="@Icons.Material.Filled.Delete" OnClick="@(() => RemovePlayer(context))">Remove</MudMenuItem>
                                </MudMenu>
                                <span>@context.PlayerName</span>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="Tag" Style="font-family:monospace;">@context.PlayerTag</MudTd>
                        <MudTd DataLabel="TH" Style="text-align:center">@context.PlayerThLevel</MudTd>
                        @if (_champStyle)
                        {
                            <MudTd DataLabel="Max Def" Style="text-align:center">@(context.MaxDefeneses ? "Yes" : "No")</MudTd>
                        }
                        @foreach (var day in DayFlags)
                        {
                            var available = IsAvailable(context, day);
                            var playing = context.EffectiveRosterDays.HasFlag(day);
                            <MudTd Style="@DayCellStyle(available, playing)">
                                <MudTooltip Text="@(available ? null : "Player opted out of this day")" Disabled="available">
                                    <MudCheckBox T="bool" Dense="true" Color="Color.Success"
                                                 Value="playing"
                                                 ValueChanged="@(v => OnDayToggled(context, day, v))" />
                                </MudTooltip>
                            </MudTd>
                        }
                        <MudTd DataLabel="Bonus" Style="text-align:center">@(context.Bonus ? "Yes" : "No")</MudTd>
                        <MudTd DataLabel="War pref" Class="sticky-col-right" Style="text-align:center">
                            <span class="wp-abbr" title="@context.WarPreference">@WarPrefAbbr(context.WarPreference)</span><span class="wp-full">@context.WarPreference</span>
                        </MudTd>
                        <MudTd Class="sticky-col-days" Style="text-align:center">@PlayingDayCount(context)</MudTd>
                    </RowTemplate>
                </MudTable>
            </div>
            <MudText Typo="Typo.caption" Class="mt-2 d-block mud-text-secondary">
                <span style="@SwatchStyle(ColPlaying)"></span> playing &nbsp;
                <span style="@SwatchStyle(ColBenched)"></span> benched by leadership &nbsp;
                <span style="@SwatchStyle(ColOptedOut)"></span> player opted out &nbsp;
                <span style="@SwatchStyle(ColOverride)"></span> opted out but rostered &nbsp;—&nbsp;
                the number under each day is how many are rostered (green = matches @_targetSize).
            </MudText>
        }

        @if (_showHidden && _hidden is { Count: > 0 })
        {
            <MudPaper Outlined="true" Class="pa-3 mt-4">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Hidden players</MudText>
                @foreach (var h in _hidden)
                {
                    <div style="display:flex;align-items:center;gap:8px;" class="mb-1">
                        <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small"
                                       Title="Unhide" OnClick="@(() => UnhidePlayer(h))" />
                        <span>@h.PlayerName</span>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">TH@(h.PlayerThLevel) · @h.PlayerTag</MudText>
                    </div>
                }
            </MudPaper>
        }

        <MudDialog @bind-Visible="_addOpen" Options="_dialogOptions">
            <TitleContent>Add player</TitleContent>
            <DialogContent>
                @* CoerceText=false so a pasted/typed tag that matches no suggestion is kept (not wiped
                   back to the null selection on blur) — that's how you add a player who isn't listed. *@
                <MudAutocomplete T="PlayerSuggestion" Label="Player" Placeholder="Start typing a name…"
                                 SearchFunc="SearchPlayers" ToStringFunc="@(p => p?.Label)"
                                 @bind-Value="_addPlayer" @bind-Text="_addTag"
                                 Immediate="true" Clearable="true" ResetValueOnEmptyText="true"
                                 CoerceText="false" MaxItems="25" Class="mb-3" />
                <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-3">
                    Pick a player, or type an exact tag for someone not listed.
                </MudText>
                <MudSelect T="WarPreference" @bind-Value="_addPref" Label="War preference" Class="mb-3">
                    @foreach (var p in Enum.GetValues<WarPreference>())
                    {
                        <MudSelectItem Value="p">@p</MudSelectItem>
                    }
                </MudSelect>
                <MudCheckBox T="bool" @bind-Value="_addBonus" Label="Bonus" Color="Color.Primary" />
            </DialogContent>
            <DialogActions>
                <MudButton OnClick="@(() => _addOpen = false)" Disabled="_adding">Cancel</MudButton>
                <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SubmitAdd" Disabled="_adding">
                    @(_adding ? "Adding…" : "Add")
                </MudButton>
            </DialogActions>
        </MudDialog>

        <MudDialog @bind-Visible="_moveOpen" Options="_dialogOptions">
            <TitleContent>Move @_moveTarget?.PlayerName</TitleContent>
            <DialogContent>
                @if (_moveClans.Count == 0)
                {
                    <MudText Typo="Typo.body2">No other clans to move to.</MudText>
                }
                else
                {
                    <MudSelect T="string" @bind-Value="_moveClanTag" Label="Destination clan">
                        @foreach (var c in _moveClans)
                        {
                            <MudSelectItem Value="c.Tag">@c.Name</MudSelectItem>
                        }
                    </MudSelect>
                }
            </DialogContent>
            <DialogActions>
                <MudButton OnClick="@(() => _moveOpen = false)" Disabled="_moving">Cancel</MudButton>
                <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SubmitMove"
                           Disabled="@(_moving || string.IsNullOrEmpty(_moveClanTag))">Move</MudButton>
            </DialogActions>
        </MudDialog>
    </Authorized>
</AuthorizeView>

@code {
    private static readonly RosterDays[] DayFlags =
    [
        RosterDays.Day1, RosterDays.Day2, RosterDays.Day3, RosterDays.Day4,
        RosterDays.Day5, RosterDays.Day6, RosterDays.Day7
    ];

    [Parameter] public string ClanTag { get; set; } = string.Empty;

    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private List<CwlSignup>? _signups;
    private bool _champStyle;
    private string _clanName = string.Empty;
    private int _targetSize = 15;
    private bool _solving;
    private string _actor = "unknown"; // "username (discordId)" of the signed-in leader, for the audit log
    private ElementReference _scrollContainer;
    private bool _stickyRightInit;

    private List<CwlSignup>? _hidden;
    private bool _showHidden;
    // Add-player dialog
    private bool _addOpen;
    private bool _adding;
    private PlayerSuggestion? _addPlayer;   // picked from the suggestions
    private string _addTag = string.Empty;  // raw typed text, used when nothing is picked
    private WarPreference _addPref = WarPreference.Alternate;
    private bool _addBonus;
    // Move dialog
    private bool _moveOpen;
    private bool _moving;
    private CwlSignup? _moveTarget;
    private string? _moveClanTag;
    private List<(string Tag, string Name)> _moveClans = new();
    private static readonly DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };

    // Wire up the pinned right-most column's scroll watcher once the table has rendered.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_signups is { Count: > 0 } && !_stickyRightInit)
        {
            _stickyRightInit = true;
            try
            {
                await JS.InvokeVoidAsync("initRosterStickyRight", _scrollContainer);
            }
            catch (JSDisconnectedException) { /* circuit torn down mid-navigation — nothing to wire up */ }
            catch (JSException) { /* element already detached (fast tab switch) — safe to ignore */ }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _clanName = ClanTag;
        if (AuthState is null)
            return;

        var user = (await AuthState).User;
        if (!user.IsInRole(AuthRoles.RosterAccess))
            return;

        // Discord username + user id, recorded on every action in the audit log.
        _actor = $"{user.Identity?.Name ?? "unknown"} ({user.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "?"})";

        _clanName = await ClanNames.GetNameOrTagAsync(ClanTag);
        _champStyle = await Rosters.IsChampStyleAsync(ClanTag);
        _signups = await Rosters.GetRosterAsync(ClanTag);
        _hidden = await Rosters.GetHiddenAsync(ClanTag);
        _targetSize = _signups.Count >= 30 ? 30 : 15; // 30v30 once a clan has 30+ signed up
    }

    // RosterDays and OptOutDays share the same bit layout, so a day flag value maps directly.
    private static bool IsAvailable(CwlSignup s, RosterDays day) => ((int)s.OptOutDays & (int)day) == 0;

    private int DayCount(RosterDays day) => _signups?.Count(s => s.EffectiveRosterDays.HasFlag(day)) ?? 0;

    // Number of days a player is rostered (count of set day flags).
    private static int PlayingDayCount(CwlSignup s) => DayFlags.Count(d => s.EffectiveRosterDays.HasFlag(d));

    private static string WarPrefAbbr(WarPreference p) => p switch
    {
        WarPreference.FWA => "F",
        WarPreference.Alternate => "A",
        WarPreference.EightStars => "8",
        WarPreference.Always => "W",
        _ => "?"
    };

    private Color CountColor(int count) =>
        count == _targetSize ? Color.Success : count > _targetSize ? Color.Error : Color.Warning;

    // Reset to default availability and auto-solve over-capacity days, then persist the whole lineup.
    private async Task SolveRoster()
    {
        if (_signups is null || _signups.Count == 0)
            return;

        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Solve roster",
            $"This resets every player to their default availability and re-solves the {_targetSize}v{_targetSize} "
            + "lineup from scratch — any manual day edits will be lost. Continue?",
            yesText: "Solve", cancelText: "Cancel");
        if (confirmed != true)
            return;

        _solving = true;
        try
        {
            RosterSolver.Solve(_signups, _targetSize);
            var values = _signups.ToDictionary(s => s.Id, s => s.EffectiveRosterDays);
            await Rosters.SetRosterDaysBulkAsync(values);
            Logger.LogInformation("{Actor} solved the {Clan} roster ({Size}v{Size}, {Count} signups)",
                _actor, _clanName, _targetSize, _targetSize, _signups.Count);
            Snackbar.Add("Roster solved and saved.", Severity.Success);
        }
        catch
        {
            // Resync the grid to the DB so it doesn't show an unsaved solved state.
            _signups = await Rosters.GetRosterAsync(ClanTag);
            Snackbar.Add("Couldn't save the solved roster. Please try again.", Severity.Error);
        }
        finally
        {
            _solving = false;
        }
    }

    private void OpenAdd()
    {
        _addPlayer = null;
        _addTag = string.Empty;
        _addPref = WarPreference.Alternate;
        _addBonus = false;
        _addOpen = true;
    }

    // Suggest cached players by name substring, exactly like the bot's PlayerTagAutocompleteHandler.
    private async Task<IEnumerable<PlayerSuggestion>> SearchPlayers(string value, CancellationToken ct)
        => await PlayerSuggestions.SearchAsync(value, ct);

    private async Task SubmitAdd()
    {
        // Prefer the picked suggestion's tag; fall back to whatever tag was typed for an unlisted player.
        var tag = _addPlayer?.Tag ?? _addTag;
        _adding = true;
        try
        {
            var result = await Rosters.AddSignupAsync(ClanTag, tag, _addPref, _addBonus);
            if (!result.Ok)
            {
                Snackbar.Add(result.Message, Severity.Error);
                return; // keep the dialog open so they can correct the tag
            }
            _addOpen = false;
            Logger.LogInformation("{Actor} added {Player} ({Tag}) to {Clan} — pref {Pref}, bonus {Bonus}",
                _actor, result.PlayerName ?? tag, tag, _clanName, _addPref, _addBonus);
            Snackbar.Add(result.Message, Severity.Success);
            await ReloadAsync();
        }
        finally
        {
            _adding = false;
        }
    }

    private async Task OpenMove(CwlSignup signup)
    {
        _moveTarget = signup;
        _moveClanTag = null;
        var clans = await Rosters.GetSignupClansAsync();
        var options = new List<(string Tag, string Name)>();
        foreach (var c in clans.Where(c => c.ClanTag != ClanTag))
            options.Add((c.ClanTag, await ClanNames.GetNameOrTagAsync(c.ClanTag)));
        _moveClans = options;
        _moveOpen = true;
    }

    private async Task SubmitMove()
    {
        if (_moveTarget is null || string.IsNullOrEmpty(_moveClanTag))
            return;

        _moving = true;
        try
        {
            await Rosters.MoveSignupAsync(_moveTarget.Id, _moveClanTag);
            var destName = _moveClans.FirstOrDefault(c => c.Tag == _moveClanTag).Name ?? _moveClanTag;
            Logger.LogInformation("{Actor} moved {Player} ({Tag}) from {FromClan} to {ToClan}",
                _actor, _moveTarget.PlayerName, _moveTarget.PlayerTag, _clanName, destName);
            _moveOpen = false;
            Snackbar.Add($"Moved {_moveTarget.PlayerName}.", Severity.Success);
            await ReloadAsync();
        }
        catch
        {
            Snackbar.Add("Couldn't move the player. Please try again.", Severity.Error);
        }
        finally
        {
            _moving = false;
        }
    }

    private async Task HidePlayer(CwlSignup signup) => await SetHidden(signup, true);

    private async Task UnhidePlayer(CwlSignup signup) => await SetHidden(signup, false);

    private async Task SetHidden(CwlSignup signup, bool hidden)
    {
        try
        {
            await Rosters.SetHiddenAsync(signup.Id, hidden);
            Logger.LogInformation("{Actor} {Action} {Player} ({Tag}) in {Clan}",
                _actor, hidden ? "hid" : "unhid", signup.PlayerName, signup.PlayerTag, _clanName);
            Snackbar.Add($"{(hidden ? "Hid" : "Unhid")} {signup.PlayerName}.", Severity.Success);
            await ReloadAsync();
        }
        catch
        {
            Snackbar.Add($"Couldn't {(hidden ? "hide" : "unhide")} the player. Please try again.", Severity.Error);
        }
    }

    private async Task RemovePlayer(CwlSignup signup)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Remove signup",
            $"Remove {signup.PlayerName} from the signups entirely? This can't be undone.",
            yesText: "Remove", cancelText: "Cancel");
        if (confirmed != true)
            return;

        try
        {
            await Rosters.DeleteSignupAsync(signup.Id);
            Logger.LogInformation("{Actor} removed {Player} ({Tag}) from {Clan}",
                _actor, signup.PlayerName, signup.PlayerTag, _clanName);
            Snackbar.Add($"Removed {signup.PlayerName}.", Severity.Success);
            await ReloadAsync();
        }
        catch
        {
            Snackbar.Add("Couldn't remove the player. Please try again.", Severity.Error);
        }
    }

    // Re-fetch both lists after any mutation so the grid, totals, and hidden section stay in sync.
    private async Task ReloadAsync()
    {
        _signups = await Rosters.GetRosterAsync(ClanTag);
        _hidden = await Rosters.GetHiddenAsync(ClanTag);
        if (_hidden.Count == 0)
            _showHidden = false;
    }

    private async Task DownloadImage()
    {
        if (_signups is null || _signups.Count == 0)
            return;

        var bytes = RosterImage.Generate(_clanName, _signups, dark: true);
        var base64 = Convert.ToBase64String(bytes);
        var fileName = $"{_clanName}-cwl-roster.png".Replace(' ', '_');
        await JS.InvokeVoidAsync("downloadFile", fileName, "image/png", base64);
    }

    // Day-cell colours. Kept as constants so the table and the legend stay in sync.
    private const string ColPlaying = "rgba(56,142,60,0.32)";   // green — rostered, player was available
    private const string ColBenched = "rgba(251,192,45,0.25)";  // yellow — available, but benched by leadership
    private const string ColOptedOut = "rgba(211,47,47,0.25)";  // red — the player opted out themselves
    // green/red caution stripes — rostered despite the player opting out (leadership override).
    // Stripe alphas match the solid green/red above (0.32 / 0.25).
    private const string ColOverride =
        "repeating-linear-gradient(45deg,rgba(56,142,60,0.32) 0,rgba(56,142,60,0.32) 7px,rgba(211,47,47,0.25) 7px,rgba(211,47,47,0.25) 14px)";

    private static string DayCellStyle(bool available, bool playing)
    {
        string bg = playing
            ? (available ? ColPlaying : ColOverride)   // rostered; striped if the player had opted out
            : (available ? ColBenched : ColOptedOut);  // not rostered; red if the player opted out
        return $"text-align:center;background:{bg}";
    }

    private static string SwatchStyle(string bg) =>
        $"display:inline-block;width:0.9em;height:0.9em;vertical-align:middle;border-radius:2px;background:{bg};";

    private async Task OnDayToggled(CwlSignup signup, RosterDays day, bool playing)
    {
        var previous = signup.RosterDays;
        var current = signup.EffectiveRosterDays;
        signup.RosterDays = playing ? current | day : current & ~day; // optimistic

        try
        {
            await Rosters.SetRosterDaysAsync(signup.Id, signup.RosterDays.Value);
            Logger.LogInformation("{Actor} set {Player} ({Tag}) {Direction} {Day} in {Clan}",
                _actor, signup.PlayerName, signup.PlayerTag, playing ? "IN" : "OUT", day, _clanName);
        }
        catch
        {
            signup.RosterDays = previous; // revert on failure
            Snackbar.Add($"Couldn't save the change for {signup.PlayerName}. Please try again.", Severity.Error);
        }
    }
}
