@page "/roster/{ClanTag}"
@inject RosterService Rosters
@inject ClanNameService ClanNames
@inject RosterImageService RosterImage
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS

<PageTitle>Roster @_clanName</PageTitle>

<MudButton Href="/" StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text" Class="mb-3">All clans</MudButton>

<AuthorizeView Roles="@AuthRoles.RosterAccess" Context="auth">
    <NotAuthorized>
        @if (auth.User.Identity?.IsAuthenticated == true)
        {
            <MudAlert Severity="Severity.Warning">
                Signed in as <b>@auth.User.Identity.Name</b>, but your account doesn't have roster access.
            </MudAlert>
        }
        else
        {
            <MudAlert Severity="Severity.Info">
                Please <MudLink Href="/account/login">sign in with Discord</MudLink> to view this roster.
            </MudAlert>
        }
    </NotAuthorized>
    <Authorized>
        <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Class="mb-4">
            <div>
                <MudText Typo="Typo.h5">@_clanName</MudText>
                <MudText Typo="Typo.caption" Style="font-family:monospace;">@ClanTag</MudText>
            </div>
            <MudSpacer />
            <MudButton OnClick="SolveRoster" StartIcon="@Icons.Material.Filled.AutoFixHigh"
                       Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Class="mr-2"
                       Disabled="@(_signups is null || _signups.Count == 0 || _solving)">
                Solve roster
            </MudButton>
            <MudButton OnClick="DownloadImage" StartIcon="@Icons.Material.Filled.Download"
                       Variant="Variant.Outlined" Size="Size.Small" Class="mr-2"
                       Disabled="@(_signups is null || _signups.Count == 0)">
                Download image
            </MudButton>
            <div>
                <MudText Typo="Typo.caption" Class="d-block">War size</MudText>
                <MudToggleGroup T="int" @bind-Value="_targetSize" Size="Size.Small" Color="Color.Primary">
                    <MudToggleItem Value="15">15v15</MudToggleItem>
                    <MudToggleItem Value="30">30v30</MudToggleItem>
                </MudToggleGroup>
            </div>
        </MudStack>

        <MudText Typo="Typo.body2" Class="mb-4 mud-text-secondary">
            Tick the days each player should play. Defaults to their declared availability; changes save automatically.
        </MudText>

        @if (_signups is null)
        {
            <MudProgressCircular Indeterminate="true" />
        }
        else if (_signups.Count == 0)
        {
            <MudText>No active signups for this clan.</MudText>
        }
        else
        {
            <div class="roster-scroll" @ref="_scrollContainer">
                <MudTable Items="_signups" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.None">
                    <HeaderContent>
                        <MudTh Class="sticky-col">Player</MudTh>
                        <MudTh>Tag</MudTh>
                        <MudTh Style="text-align:center">TH</MudTh>
                        @if (_champStyle)
                        {
                            <MudTh Style="text-align:center">Max&nbsp;Def</MudTh>
                        }
                        @for (var d = 1; d <= 7; d++)
                        {
                            var dayNum = d;
                            var flag = DayFlags[d - 1];
                            var count = DayCount(flag);
                            <MudTh Style="text-align:center">
                                D@(dayNum)<br />
                                <MudText Inline="true" Typo="Typo.body2" Color="@CountColor(count)"><b>@count</b></MudText>
                            </MudTh>
                        }
                        <MudTh Style="text-align:center">Bonus</MudTh>
                        <MudTh Class="sticky-col-right" Style="text-align:center">
                            <span class="wp-abbr">WP</span><span class="wp-full">War pref</span>
                        </MudTh>
                        <MudTh Class="sticky-col-days" Style="text-align:center" title="Days rostered">#</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Player" Class="sticky-col">@context.PlayerName</MudTd>
                        <MudTd DataLabel="Tag" Style="font-family:monospace;">@context.PlayerTag</MudTd>
                        <MudTd DataLabel="TH" Style="text-align:center">@context.PlayerThLevel</MudTd>
                        @if (_champStyle)
                        {
                            <MudTd DataLabel="Max Def" Style="text-align:center">@(context.MaxDefeneses ? "Yes" : "No")</MudTd>
                        }
                        @foreach (var day in DayFlags)
                        {
                            var available = IsAvailable(context, day);
                            var playing = context.EffectiveRosterDays.HasFlag(day);
                            <MudTd Style="@DayCellStyle(available, playing)">
                                <MudTooltip Text="@(available ? null : "Player opted out of this day")" Disabled="available">
                                    <MudCheckBox T="bool" Dense="true" Color="Color.Success"
                                                 Value="playing"
                                                 ValueChanged="@(v => OnDayToggled(context, day, v))" />
                                </MudTooltip>
                            </MudTd>
                        }
                        <MudTd DataLabel="Bonus" Style="text-align:center">@(context.Bonus ? "Yes" : "No")</MudTd>
                        <MudTd DataLabel="War pref" Class="sticky-col-right" Style="text-align:center">
                            <span class="wp-abbr" title="@context.WarPreference">@WarPrefAbbr(context.WarPreference)</span><span class="wp-full">@context.WarPreference</span>
                        </MudTd>
                        <MudTd Class="sticky-col-days" Style="text-align:center">@PlayingDayCount(context)</MudTd>
                    </RowTemplate>
                </MudTable>
            </div>
            <MudText Typo="Typo.caption" Class="mt-2 d-block mud-text-secondary">
                <span style="@SwatchStyle(ColPlaying)"></span> playing &nbsp;
                <span style="@SwatchStyle(ColBenched)"></span> benched by leadership &nbsp;
                <span style="@SwatchStyle(ColOptedOut)"></span> player opted out &nbsp;
                <span style="@SwatchStyle(ColOverride)"></span> opted out but rostered &nbsp;—&nbsp;
                the number under each day is how many are rostered (green = matches @_targetSize).
            </MudText>
        }
    </Authorized>
</AuthorizeView>

@code {
    private static readonly RosterDays[] DayFlags =
    [
        RosterDays.Day1, RosterDays.Day2, RosterDays.Day3, RosterDays.Day4,
        RosterDays.Day5, RosterDays.Day6, RosterDays.Day7
    ];

    [Parameter] public string ClanTag { get; set; } = string.Empty;

    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private List<CwlSignup>? _signups;
    private bool _champStyle;
    private string _clanName = string.Empty;
    private int _targetSize = 15;
    private bool _solving;
    private ElementReference _scrollContainer;
    private bool _stickyRightInit;

    // Wire up the pinned right-most column's scroll watcher once the table has rendered.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_signups is { Count: > 0 } && !_stickyRightInit)
        {
            _stickyRightInit = true;
            await JS.InvokeVoidAsync("initRosterStickyRight", _scrollContainer);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _clanName = ClanTag;
        if (AuthState is null || !(await AuthState).User.IsInRole(AuthRoles.RosterAccess))
            return;

        _clanName = await ClanNames.GetNameOrTagAsync(ClanTag);
        _champStyle = await Rosters.IsChampStyleAsync(ClanTag);
        _signups = await Rosters.GetRosterAsync(ClanTag);
        _targetSize = _signups.Count >= 30 ? 30 : 15; // 30v30 once a clan has 30+ signed up
    }

    // RosterDays and OptOutDays share the same bit layout, so a day flag value maps directly.
    private static bool IsAvailable(CwlSignup s, RosterDays day) => ((int)s.OptOutDays & (int)day) == 0;

    private int DayCount(RosterDays day) => _signups?.Count(s => s.EffectiveRosterDays.HasFlag(day)) ?? 0;

    // Number of days a player is rostered (count of set day flags).
    private static int PlayingDayCount(CwlSignup s) => DayFlags.Count(d => s.EffectiveRosterDays.HasFlag(d));

    private static string WarPrefAbbr(WarPreference p) => p switch
    {
        WarPreference.FWA => "F",
        WarPreference.Alternate => "A",
        WarPreference.EightStars => "8",
        WarPreference.Always => "W",
        _ => "?"
    };

    private Color CountColor(int count) =>
        count == _targetSize ? Color.Success : count > _targetSize ? Color.Error : Color.Warning;

    // Reset to default availability and auto-solve over-capacity days, then persist the whole lineup.
    private async Task SolveRoster()
    {
        if (_signups is null || _signups.Count == 0)
            return;

        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Solve roster",
            $"This resets every player to their default availability and re-solves the {_targetSize}v{_targetSize} "
            + "lineup from scratch — any manual day edits will be lost. Continue?",
            yesText: "Solve", cancelText: "Cancel");
        if (confirmed != true)
            return;

        _solving = true;
        try
        {
            RosterSolver.Solve(_signups, _targetSize);
            var values = _signups.ToDictionary(s => s.Id, s => s.EffectiveRosterDays);
            await Rosters.SetRosterDaysBulkAsync(values);
            Snackbar.Add("Roster solved and saved.", Severity.Success);
        }
        catch
        {
            // Resync the grid to the DB so it doesn't show an unsaved solved state.
            _signups = await Rosters.GetRosterAsync(ClanTag);
            Snackbar.Add("Couldn't save the solved roster. Please try again.", Severity.Error);
        }
        finally
        {
            _solving = false;
        }
    }

    private async Task DownloadImage()
    {
        if (_signups is null || _signups.Count == 0)
            return;

        var bytes = RosterImage.Generate(_clanName, _signups, dark: true);
        var base64 = Convert.ToBase64String(bytes);
        var fileName = $"{_clanName}-cwl-roster.png".Replace(' ', '_');
        await JS.InvokeVoidAsync("downloadFile", fileName, "image/png", base64);
    }

    // Day-cell colours. Kept as constants so the table and the legend stay in sync.
    private const string ColPlaying = "rgba(56,142,60,0.32)";   // green — rostered, player was available
    private const string ColBenched = "rgba(251,192,45,0.25)";  // yellow — available, but benched by leadership
    private const string ColOptedOut = "rgba(211,47,47,0.25)";  // red — the player opted out themselves
    // green/red caution stripes — rostered despite the player opting out (leadership override).
    // Stripe alphas match the solid green/red above (0.32 / 0.25).
    private const string ColOverride =
        "repeating-linear-gradient(45deg,rgba(56,142,60,0.32) 0,rgba(56,142,60,0.32) 7px,rgba(211,47,47,0.25) 7px,rgba(211,47,47,0.25) 14px)";

    private static string DayCellStyle(bool available, bool playing)
    {
        string bg = playing
            ? (available ? ColPlaying : ColOverride)   // rostered; striped if the player had opted out
            : (available ? ColBenched : ColOptedOut);  // not rostered; red if the player opted out
        return $"text-align:center;background:{bg}";
    }

    private static string SwatchStyle(string bg) =>
        $"display:inline-block;width:0.9em;height:0.9em;vertical-align:middle;border-radius:2px;background:{bg};";

    private async Task OnDayToggled(CwlSignup signup, RosterDays day, bool playing)
    {
        var previous = signup.RosterDays;
        var current = signup.EffectiveRosterDays;
        signup.RosterDays = playing ? current | day : current & ~day; // optimistic

        try
        {
            await Rosters.SetRosterDaysAsync(signup.Id, signup.RosterDays.Value);
        }
        catch
        {
            signup.RosterDays = previous; // revert on failure
            Snackbar.Add($"Couldn't save the change for {signup.PlayerName}. Please try again.", Severity.Error);
        }
    }
}
