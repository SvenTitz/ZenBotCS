@page "/clans"
@inject RosterService Roster
@inject ClanNameService ClanNames

<PageTitle>Clans</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Clans</MudText>

<AuthorizeView Roles="@AuthRoles.RosterAccess">
    <NotAuthorized>
        <AccessDenied What="the clans" Authenticated="context.User.Identity?.IsAuthenticated == true" />
    </NotAuthorized>
    <Authorized>
        @if (_clans is null)
        {
            <MudProgressCircular Indeterminate="true" />
        }
        else if (_clans.Count == 0)
        {
            <MudText>No clans available.</MudText>
        }
        else
        {
            <ClanGroups Clans="_clans" Names="_names" />
        }
    </Authorized>
</AuthorizeView>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private List<ClanListItem>? _clans;
    private IReadOnlyDictionary<string, string> _names = new Dictionary<string, string>();

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is null || !(await AuthState).User.IsInRole(AuthRoles.RosterAccess))
            return;

        _clans = await Roster.GetClansByTypeAsync();
        _names = await ClanNames.GetAllAsync();
    }
}
