@* Consistent empty state for features whose UI isn't built yet. *@
<MudPaper Outlined="true" Class="pa-8 d-flex flex-column align-center" Style="text-align:center">
    <MudIcon Icon="@Icon" Size="Size.Large" Color="Color.Primary" Class="mb-2" />
    <MudText Typo="Typo.h6">@Feature</MudText>
    <MudText Typo="Typo.body2" Style="color:var(--mud-palette-text-secondary)">
        @(string.IsNullOrEmpty(Note) ? "Coming soon." : Note)
    </MudText>
</MudPaper>

@code {
    [Parameter, EditorRequired] public string Feature { get; set; } = string.Empty;
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.Construction;
    [Parameter] public string? Note { get; set; }
}
